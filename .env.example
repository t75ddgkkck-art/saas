# ============================================================================
# VITRIX — Variables d'environnement (Lot 39 refonte lancement)
# ============================================================================
#
# Instructions :
#  1. Copier ce fichier en `.env.local` (dev) ou coller les vars dans Vercel
#  2. Remplir les REQUIS ci-dessous → l'app plante au boot sinon (health check)
#  3. Les OPTIONNELS activent des features (features toggle automatique)
#
# Groupes :
#  [1] REQUIS BASE       — sans quoi l'app ne démarre pas
#  [2] REQUIS PAIEMENT   — sans quoi Stripe/abonnements ne fonctionnent pas
#  [3] REQUIS EMAIL      — sans quoi aucun email n'est envoyé (RDV/devis/reset)
#  [4] OPT SÉCURITÉ      — captcha, brute-force, monitoring
#  [5] OPT IA            — assistant, blog, quote generator
#  [6] OPT NOTIFS PUSH   — VAPID (Web Push OS)
#  [7] OPT STOCKAGE      — Supabase Storage (uploads)
#  [8] OPT SMS/WA        — Twilio, WhatsApp
#  [9] OPT INTÉGRATIONS  — Google Calendar, Google Business
#  [10] OPT SUPPORT      — Crisp / Intercom (widget chat visiteur)
#  [11] OPT MONITORING   — Sentry, alertes webhook
#
# Vérification post-config : GET /api/health → status détaillé par intégration.
# ============================================================================


# ============================================================================
# [1] REQUIS BASE — sans ça l'app plante au boot
# ============================================================================

# URL publique de l'app (SANS trailing slash). Utilisée pour :
#  - Liens dans les emails transactionnels
#  - OAuth redirect URIs
#  - Base URL des webhooks
#  - Sitemap / robots.txt / OpenGraph
NEXT_PUBLIC_APP_URL=https://www.vitrix.fr

# Base de données PostgreSQL (Supabase recommandé).
# Format Supabase pooler : postgresql://postgres.[REF]:[PWD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Format Neon/RDS : postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/vitrix

# Secret HMAC pour signer les cookies de session (min 32 chars).
# Génère avec : `openssl rand -base64 32`
# ⛔ NE JAMAIS commit — rotation immédiate si fuite (invalide toutes les sessions).
NEXTAUTH_SECRET=change-me-openssl-rand-base64-32

# Secret pour authentifier les crons Vercel (header Authorization: Bearer $CRON_SECRET).
# Génère : `openssl rand -hex 32`
CRON_SECRET=change-me-openssl-rand-hex-32


# ============================================================================
# [2] REQUIS PAIEMENT — Stripe (indispensable pour abonnements Pro/Premium)
# ============================================================================

# Clé secrète serveur (test : sk_test_..., prod : sk_live_...)
STRIPE_SECRET_KEY=sk_test_...

# Secret webhook (à récupérer dans Stripe → Developers → Webhooks après création de l'endpoint)
# Endpoint à créer : https://votre-app/api/stripe/webhook
# Events à cocher : checkout.session.completed, checkout.session.expired,
#                   customer.subscription.updated/deleted/trial_will_end,
#                   invoice.paid/payment_failed/upcoming, charge.dispute.created
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs Stripe (créer 4 produits récurrents dans Stripe Dashboard)
# Pro mensuel 29€, Pro annuel 278€ (2 mois offerts), Premium mensuel 79€, Premium annuel 758€
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_YEARLY=price_...
STRIPE_PRICE_ID_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_ID_PREMIUM_YEARLY=price_...

# Email de contact envoyé sur les factures Stripe (facultatif, défaut support@vitrix.fr)
STRIPE_SUPPORT_EMAIL=support@vitrix.fr


# ============================================================================
# [3] REQUIS EMAIL — Resend (aucun email envoyé sans ça)
# ============================================================================

# Clé API Resend (re_...) — créer un compte gratuit sur https://resend.com
RESEND_API_KEY=re_...

# Email expéditeur — DOIT être un domaine vérifié dans Resend (DKIM/SPF)
# Sinon : les emails partent en spam ou sont rejetés.
RESEND_FROM_EMAIL=noreply@vitrix.fr
RESEND_FROM_NAME=Vitrix
RESEND_REPLY_TO=support@vitrix.fr


# ============================================================================
# [4] OPT SÉCURITÉ
# ============================================================================

# Cloudflare Turnstile (captcha invisible sur login/register)
# Créer sur : https://dash.cloudflare.com/?to=/:account/turnstile
# Sans ces vars → captcha désactivé, brute-force plus facile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Seuil brute-force : nombre d'échecs login /h/IP avant blocage 1h (défaut 30)
BRUTE_FORCE_THRESHOLD=30


# ============================================================================
# [5] OPT IA — OpenAI (assistant chat, génération blog, devis IA)
# ============================================================================

# Clé API OpenAI (sk-proj-...) — sans ça : features IA désactivées avec fallbacks
OPENAI_API_KEY=

# Optionnel : override modèle par défaut (gpt-4o-mini est un bon compromis coût/qualité)
OPENAI_MODEL=gpt-4o-mini

# Optionnel : timeout requêtes IA en ms (défaut 15000)
OPENAI_TIMEOUT_MS=15000

# Optionnel : self-host OpenAI-compatible (Ollama, LocalAI, LiteLLM)
# OPENAI_BASE_URL=https://api.openai.com/v1


# ============================================================================
# [6] OPT NOTIFS PUSH — VAPID (Web Push OS)
# ============================================================================

# Générer avec : `npx web-push generate-vapid-keys`
# Sans ces vars → push OS désactivées silencieusement (in-app fonctionne)
# Nécessite aussi : `npm install web-push` (non listé dans package.json par défaut)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@vitrix.fr


# ============================================================================
# [7] OPT STOCKAGE — Supabase Storage (photos vitrine, logos, pièces jointes devis)
# ============================================================================

# Sans ces vars : upload de fichier retourne une erreur 500
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Nom du bucket à créer (Storage → New bucket → public)
SUPABASE_STORAGE_BUCKET=vitrix-uploads


# ============================================================================
# [8] OPT SMS / WHATSAPP — Twilio
# ============================================================================

# Sans ces vars : les rappels SMS/WhatsApp sont skippés silencieusement
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Budget mensuel : nombre max de SMS envoyés / user / mois (défaut Free=0, Pro=0, Premium=100)
SMS_DAILY_LIMIT=10
WHATSAPP_DAILY_LIMIT=10


# ============================================================================
# [9] OPT INTÉGRATIONS — Google
# ============================================================================

# Google Calendar : sync bidirectionnelle des RDV
# Créer un projet dans Google Cloud Console → OAuth 2.0 Client ID → Web application
# Autoriser le redirect URI : {NEXT_PUBLIC_APP_URL}/api/google/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# Google Business Profile (avis, place ID) — partage le même client OAuth
GOOGLE_REDIRECT_URI=

# Google Places API (autocomplete adresses register) — optionnel
GOOGLE_PLACES_API_KEY=

# Google refresh token pour un compte service (rare — cas très spécifique)
# GOOGLE_REFRESH_TOKEN=


# ============================================================================
# [10] OPT SUPPORT — widget chat visiteur (Crisp OU Intercom, pas les 2)
# ============================================================================

# Crisp — https://crisp.chat (gratuit)
NEXT_PUBLIC_CRISP_ID=

# Intercom — plus enterprise
NEXT_PUBLIC_INTERCOM_APP_ID=


# ============================================================================
# [11] OPT MONITORING — Sentry + alertes webhook
# ============================================================================

# Sentry — https://sentry.io (5 GB/mois gratuit)
# Sans ces vars : logs uniquement (pas de tracking d'erreur externe)
# Nécessite aussi : `npm install @sentry/nextjs` (non listé dans package.json)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Webhook Slack/Discord/Teams pour recevoir les alertes critiques (5xx, brute-force)
# Type : "slack", "discord", "teams" (auto-détecté depuis l'URL sinon)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TYPE=slack

# Niveau min d'alerte remontée au webhook : "debug" | "info" | "warn" | "error" | "critical"
# Défaut : "error" (évite le spam en dev)
ALERT_MIN_LEVEL=error


# ============================================================================
# [12] OPT DIVERS
# ============================================================================

# Niveau de log serveur : "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# Nom app affiché (défaut "Vitrix")
NEXT_PUBLIC_APP_NAME=Vitrix

# Jours de rétention des comptes soft-deleted avant purge cron (défaut 30)
RGPD_PURGE_DAYS=30

# Désactive la télémetrie Next.js (privacy + build plus rapide)
NEXT_TELEMETRY_DISABLED=1


# ============================================================================
# Variables auto-injectées par Vercel (NE PAS METTRE ICI)
# ============================================================================
# VERCEL_ENV                → "production" | "preview" | "development"
# VERCEL_GIT_COMMIT_SHA     → SHA du commit déployé (utilisé par /api/health)
# NODE_ENV                  → "production" en build/runtime Vercel
