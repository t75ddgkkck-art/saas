# ===========================================
# ArtisanPro - Variables d'environnement
# ===========================================

# ===========================================
# OPTION 1: Render + Supabase (Recommandé)
# ===========================================

# Supabase (Base de données PostgreSQL)
# Récupérez la connection string dans: Settings > Database > Connection string
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# URL de l'application (votre domaine Render)
NEXT_PUBLIC_APP_URL=https://votre-app.onrender.com

# ===========================================
# OPTION 2: Vercel + Supabase
# ===========================================

# Supabase (même connection string que ci-dessus)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# URL de l'application (automatique sur Vercel, mais configurable)
NEXT_PUBLIC_APP_URL=https://votre-app.vercel.app

# ===========================================
# AUTHENTIFICATION (Commun aux deux)
# ===========================================

# Clé secrète pour les tokens de session
# Générez avec: openssl rand -base64 32
NEXTAUTH_SECRET=votre-clé-secrète-ici
NEXTAUTH_URL=https://votre-domaine.com

# ===========================================
# SIRET / INSEE
# ===========================================

# Optionnel - sans clé, fallback sur algorithme de Luhn
# Obtenez-la sur https://api.insee.fr/
INSEE_API_KEY=

# ===========================================
# PAIEMENTS (Stripe)
# ===========================================

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PREMIUM=price_...

# ===========================================
# ASSISTANT IA (OpenAI)
# ===========================================

OPENAI_API_KEY=sk-proj-...

# ===========================================
# EMAILS (Resend)
# ===========================================

RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@votre-domaine.com

# ===========================================
# SMS (Twilio)
# ===========================================

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...

# ===========================================
# WHATSAPP
# ===========================================

WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_ACCESS_TOKEN=...

# ===========================================
# CALENDRIER (Google)
# ===========================================

GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://votre-domaine.com/api/auth/google/callback

# ===========================================
# PWA PUSH NOTIFICATIONS
# ===========================================

# Générez votre clé VAPID sur https://web-push-codelab.glitch.me/
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:contact@votre-domaine.com

# ===========================================
# CRON JOB (Relances devis)
# ===========================================

CRON_SECRET=votre-cron-secret

# ===========================================
# STOCKAGE (Cloudflare R2 / S3)
# ===========================================

R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=artisanpro
R2_PUBLIC_URL=https://cdn.votre-domaine.com

# ===========================================
# GOOGLE OAUTH (Avis Google + Calendar)
# ===========================================

# IMPORTANT : Le redirect_uri DOIT correspondre EXACTEMENT à celui configuré
# dans Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Ajoutez https://votre-domaine.com/api/google/callback dans "Authorized redirect URIs"

GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://votre-domaine.com/api/google/callback

# Le refresh token est obtenu automatiquement la première fois que le pro
# clique sur "Importer mes avis Google" dans son dashboard.
# Il permet d'importer ses VRAIS avis Google Business (anti-faux avis).
