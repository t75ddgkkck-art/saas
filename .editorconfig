# EditorConfig — normalise l'indentation, les fins de ligne et l'encoding
# entre IDE (VS Code, Cursor, JetBrains, vim, sublime…).
# Doc : https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown : trailing whitespace = double-space (retour à la ligne intentionnel)
[*.md]
trim_trailing_whitespace = false

# Fichiers de config : on garde 2 spaces (cohérent avec le reste TS)
[*.{json,yml,yaml,toml}]
indent_size = 2

# Fichiers Windows spéciaux (rarissimes chez nous mais safe)
[*.{bat,cmd}]
end_of_line = crlf
